{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "ASF Saydo",
  "version": "1.0.0",
  "identifier": "com.asf.saydo",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "ASF Saydo",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'wasm-unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; connect-src 'self' https:"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/AI-Strategic-Forum/Saydo/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEE3NzQ3QUYyQkZCNjhENTYKUldSV2piYS84bnAwcHpEMFVNSEplM2JXWk0vVlBqOC90WWF1NCsyQWRNbk8vUGNyY21DbkhDMVYK"
    }
  }
}
